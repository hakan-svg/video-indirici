{
  "manifest_version": 3,
  "name": "PKD — Post Kreatif Downloader",
  "version": "2.5",
  "description": "Sayfadaki videoların üzerine indirme düğmesi ekler; çözünürlük seçerek yerel sunucuyla indirir.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "PKD",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["activeTab", "tabs", "storage", "cookies"],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
